    .map(Number).filter(n => !isNaN(n) && n > 0);

  let resultHTML = '';

  if (hrSensor.length >= 2 && hrClin.length === hrSensor.length) {
    const hr = linearRegression(hrSensor, hrClin);
    document.getElementById('hr_slope').value = hr.slope; // hidden fields added below
    document.getElementById('hr_offset').value = hr.offset;
    resultHTML += `<strong>HR:</strong> ${hr.slope}× + ${hr.offset}<br>`;
  }
  if (o2Sensor.length >= 2 && o2Clin.length === o2Sensor.length) {
    const o2 = linearRegression(o2Sensor, o2Clin);
    document.getElementById('o2_slope').value = o2.slope;
    document.getElementById('o2_offset').value = o2.offset;
    resultHTML += `<strong>SpO₂:</strong> ${o2.slope}× + ${o2.offset}`;
  }

  document.getElementById('calibResult').innerHTML = resultHTML || 'Enter at least 2 valid pairs per metric.';
}

