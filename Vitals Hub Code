void setupAPServer() {
  // Receive temperature from temp module
  // POST /temp  body: {"temperature":36.52,"device_id":"ESP32-001"}
  apServer.on("/temp", HTTP_POST, []() {
    String body = apServer.arg("plain");
    StaticJsonDocument<128> doc;
    if (!deserializeJson(doc, body)) {
      float t = doc["temperature"] | -99.0f;
      if (t > 10.0f && t < 50.0f) {
        moduleTemp    = t;
        gotModuleTemp = true;
        lastTempTime  = millis();
        Serial.print(F("[AP/TEMP] ")); Serial.print(moduleTemp, 1); Serial.println(F("C"));
      }
    }
    apServer.send(200, "application/json", "{\"status\":\"ok\"}");
  });

  // Receive respiration from belt module
  // POST /resp  body: {"respiration_rate":16,"device_id":"ESP32-001"}
  apServer.on("/resp", HTTP_POST, []() {
    String body = apServer.arg("plain");
    StaticJsonDocument<128> doc;
    if (!deserializeJson(doc, body)) {
      int r = doc["respiration_rate"] | -1;
      if (r >= 0 && r <= 60) {
        moduleResp    = r;
        gotModuleResp = true;
        lastRespTime  = millis();
        Serial.print(F("[AP/RESP] ")); Serial.print(moduleResp); Serial.println(F(" br/min"));
