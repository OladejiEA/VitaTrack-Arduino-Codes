  ESP.restart();
}

// ─────────────────────────────────────────────────────────────
// INTERNET WIFI (STA) MAINTENANCE
// ─────────────────────────────────────────────────────────────
void wifiMaintain() {
  bool nowConnected = (WiFi.status() == WL_CONNECTED);
  if (nowConnected && !staConnected) {
    staConnected = true;
    Serial.print(F("[WiFi] Internet: ")); Serial.println(WiFi.localIP());
    if (queuedReadings > 0) flushQueue();
  } else if (!nowConnected && staConnected) {
    staConnected = false;
    Serial.println(F("[WiFi] Internet lost — offline"));
  }
  if (!nowConnected && strlen(cfgWifiSsid) > 0 &&
      millis() - lastWifiRetry >= WIFI_RETRY_MS) {
    lastWifiRetry = millis();
    WiFi.begin(cfgWifiSsid, cfgWifiPass);
  }
  if (nowConnected && queuedReadings > 0 &&
      millis() - lastRetry >= RETRY_INTERVAL) {
    lastRetry = millis();
    flushQueue();
  }
}

// ─────────────────────────────────────────────────────────────
// SPIFFS OFFLINE QUEUE
// ─────────────────────────────────────────────────────────────
void initSPIFFS() {
  if (!SPIFFS.begin(true)) { SPIFFS.format(); SPIFFS.begin(true); }
  if (SPIFFS.exists(QUEUE_FILE)) {
    File f = SPIFFS.open(QUEUE_FILE, "r");
    if (f) {
      DynamicJsonDocument doc(8192);
      if (!deserializeJson(doc, f))
        queuedReadings = doc["readings"].as<JsonArray>().size();
      f.close();
    }
  }
  Serial.print(F("[SPIFFS] Queued: ")); Serial.println(queuedReadings);
}

void queueReadingFull(const char* hr, const char* spo2,
                      const char* temp, const char* resp) {
  DynamicJsonDocument doc(8192);
  if (SPIFFS.exists(QUEUE_FILE)) {
    File f = SPIFFS.open(QUEUE_FILE, "r");
    if (f) { deserializeJson(doc, f); f.close(); }
  }
  if (!doc.containsKey("readings")) doc.createNestedArray("readings");
  JsonArray arr = doc["readings"].as<JsonArray>();
  while ((int)arr.size() >= MAX_QUEUE) arr.remove(0);
  JsonObject r = arr.createNestedObject();
  r["hr"]        = hr;   r["spo2"]      = spo2;
  r["temp"]      = temp; r["resp"]      = resp;
  r["device_id"] = cfgDeviceId;
  File f = SPIFFS.open(QUEUE_FILE, "w");
  if (f) { serializeJson(doc, f); f.close(); }
  queuedReadings = arr.size();
  Serial.print(F("[QUEUE] Saved. Total: ")); Serial.println(queuedReadings);
}

void flushQueue() {
  if (!SPIFFS.exists(QUEUE_FILE) || queuedReadings == 0) return;
  File f = SPIFFS.open(QUEUE_FILE, "r");
  if (!f) return;
  DynamicJsonDocument doc(8192);
  if (deserializeJson(doc, f)) { f.close(); return; }
  f.close();
  JsonArray arr = doc["readings"].as<JsonArray>();
  int flushed = 0;
  for (JsonObject r : arr) {
    char payload[160];
    snprintf(payload, sizeof(payload),
      "{\"heart_rate\":%ld,\"blood_oxygen\":%ld,"
      "\"temperature\":\"%s\",\"respiration_rate\":\"%s\","
      "\"device_id\":\"%s\"}",
      r["hr"].as<long>(), r["spo2"].as<long>(),
      r["temp"].as<const char*>(), r["resp"].as<const char*>(),
      r["device_id"].as<const char*>());
    WiFiClientSecure wc; wc.setInsecure();
    HTTPClient http;
    http.begin(wc, cfgFlaskUrl);
    http.addHeader("Content-Type", "application/json");
    int code = http.POST(payload);
    http.end();
    if (code > 0) flushed++; else break;
    delay(500);
  }
  if (flushed == (int)arr.size()) {
    SPIFFS.remove(QUEUE_FILE); queuedReadings = 0;
    Serial.println(F("[FLUSH] Queue cleared"));
  } else if (flushed > 0) {
    for (int i = 0; i < flushed; i++) arr.remove(0);
    File fw = SPIFFS.open(QUEUE_FILE, "w");
    if (fw) { serializeJson(doc, fw); fw.close(); }
    queuedReadings = arr.size();
  }
  Serial.print(F("[FLUSH] Remaining: ")); Serial.println(queuedReadings);
}

// ─────────────────────────────────────────────────────────────
// FLASK POST
// ─────────────────────────────────────────────────────────────
bool postToFlaskFull(const char* hrBuf, const char* o2Buf,
                     const char* tBuf,  const char* rBuf) {
  char payload[200];
  snprintf(payload, sizeof(payload),
    "{\"heart_rate\":\"%s\",\"blood_oxygen\":\"%s\","
    "\"temperature\":\"%s\",\"respiration_rate\":\"%s\","
    "\"device_id\":\"%s\"}",
    hrBuf, o2Buf, tBuf, rBuf, cfgDeviceId);
  WiFiClientSecure wc; wc.setInsecure();
  HTTPClient http;
  http.begin(wc, cfgFlaskUrl);
  http.addHeader("Content-Type", "application/json");
  int code = http.POST(payload);
  http.end();
  Serial.print(F("[POST] code=")); Serial.println(code);
  Serial.println(payload);
  return (code > 0);
}

int32_t calcMedian(int32_t* a, int n) {
  if (n == 0) return 0;
  int32_t t[MAX_SAMPLES];
  for (int i = 0; i < n; i++) t[i] = a[i];
  for (int i = 1; i < n; i++) {
    int32_t k = t[i]; int j = i - 1;
    while (j >= 0 && t[j] > k) { t[j+1] = t[j]; j--; }
    t[j+1] = k;
  }
  return t[n/2];
}

void handleSend() {
  bool tempFresh    = gotModuleTemp && (millis() - lastTempTime < TEMP_STALE_MS);
  bool respFresh    = gotModuleResp && (millis() - lastRespTime < RESP_STALE_MS);
  bool bleRespFresh = gotResp && (millis() - lastBleRespTime < RESP_STALE_MS);
  bool hasHR        = (nSamples > 0);

  // Skip entirely if we have nothing at all to send
  if (!hasHR && !tempFresh && !respFresh && !bleRespFresh) {
    Serial.println(F("[SEND] No data — skipping"));
    return;
  }

  // HR and SpO2 — use median if we have samples, otherwise N/A
  char hrBuf[8], o2Buf[8];
  int32_t mHR = 0, mSpO2 = 0;
  if (hasHR) {
    mHR   = calcMedian(hrArr,   nSamples);
    mSpO2 = calcMedian(spo2Arr, nSamples);
    itoa((int)mHR,   hrBuf, 10);
    itoa((int)mSpO2, o2Buf, 10);
  } else {
    strcpy(hrBuf, "N/A");
    strcpy(o2Buf, "N/A");
  }

  // Temperature
  char tBuf[8];
  if (tempFresh) dtostrf(moduleTemp, 4, 1, tBuf); else strcpy(tBuf, "N/A");

  // Respiration — prefer WiFi belt, fall back to BLE
  char rBuf[8];
  if (respFresh)         itoa(moduleResp, rBuf, 10);
  else if (bleRespFresh) itoa(bleResp,    rBuf, 10);
  else                   strcpy(rBuf, "N/A");

  if (staConnected && WiFi.status() == WL_CONNECTED) {
    bool ok = postToFlaskFull(hrBuf, o2Buf, tBuf, rBuf);
    if (ok) {
      if (queuedReadings > 0) flushQueue();
      displaySendResult(ok, mHR, mSpO2, tBuf, rBuf);
    } else {
      queueReadingFull(hrBuf, o2Buf, tBuf, rBuf);
      displaySendResult(false, mHR, mSpO2, tBuf, rBuf);
    }
  } else {
    queueReadingFull(hrBuf, o2Buf, tBuf, rBuf);
    displayOfflineQueue(mHR, mSpO2, tBuf);
  }
  nSamples = 0;
}

void displaySendResult(bool ok, int32_t hr, int32_t spo2,
                        const char* t, const char* r) {
  display.clearDisplay(); display.setTextSize(1);
  display.setCursor(0, 0);
  display.println(ok ? F("Flask: SENT OK") : F("Flask: FAILED (queued)"));
  display.setCursor(0, 14); display.print(F("HR:"));  display.print(hr);   display.println(F("bpm"));
  display.setCursor(0, 24); display.print(F("O2:"));  display.print(spo2); display.println(F("%"));
  display.setCursor(0, 34); display.print(F("T:"));   display.println(t);
  display.setCursor(0, 44); display.print(F("R:"));   display.println(r);
  display.display(); delay(3000);
}

void displayOfflineQueue(int32_t hr, int32_t spo2, const char* t) {
  display.clearDisplay(); display.setTextSize(1);
  display.setCursor(0, 0);  display.println(F("OFFLINE — reading saved"));
  display.setCursor(0, 14); display.print(F("HR:"));  display.print(hr);   display.println(F("bpm"));
  display.setCursor(0, 24); display.print(F("O2:"));  display.print(spo2); display.println(F("%"));
  display.setCursor(0, 34); display.print(F("T:"));   display.println(t);
  display.setCursor(0, 46); display.print(F("Queued: ")); display.print(queuedReadings);
  display.display(); delay(3000);
}

// ─────────────────────────────────────────────────────────────
// BLE — RESPIRATION BELT (fallback)
// ─────────────────────────────────────────────────────────────
void bleMaintain() {
  bool needR = (!rClient || !rClient->isConnected());
  if (!needR) return;
  NimBLEScan* sc = NimBLEDevice::getScan();
  sc->setActiveScan(true);
  sc->start(BLE_SCAN_SECS, false);
  NimBLEScanResults res = sc->getResults();
  for (int i = 0; i < res.getCount(); i++) {
    const NimBLEAdvertisedDevice* d = res.getDevice(i);
    if (!d || d->getName() != RESP_NAME) continue;
    NimBLEClient* c = NimBLEDevice::createClient();
    if (!c->connect(d)) { NimBLEDevice::deleteClient(c); continue; }
    NimBLERemoteService*        s = c->getService(RESP_SVC);
    NimBLERemoteCharacteristic* x = s ? s->getCharacteristic(RESP_CHAR_UUID) : nullptr;
    if (!x || !x->canNotify()) { c->disconnect(); NimBLEDevice::deleteClient(c); continue; }
    x->subscribe(true, [](NimBLERemoteCharacteristic*, uint8_t* d, size_t l, bool) {
      String s = ""; for (size_t i = 0; i < l; i++) s += (char)d[i];
      bleResp = s.toInt(); gotResp = true; lastBleRespTime = millis();
    });
    rClient = c;
    Serial.println(F("[BLE] Resp belt connected"));
    break;
  }
  sc->clearResults();
}

// ─────────────────────────────────────────────────────────────
// MAX30102
// ─────────────────────────────────────────────────────────────
void collectSamples() {
  for (int i = 0; i < SPO2_BUF; i++) {
    while (!sensor.available()) sensor.check();
    redBuf[i] = sensor.getRed();
    irBuf[i]  = sensor.getIR();
    sensor.nextSample();
  }
}

bool fingerOn() {
  uint64_t s = 0;
  for (int i = 0; i < SPO2_BUF; i++) s += irBuf[i];
  return ((uint32_t)(s / SPO2_BUF) > FINGER_THRESH);
}

void measure() {
  maxim_heart_rate_and_oxygen_saturation(irBuf, SPO2_BUF, redBuf,
                                          &spo2Val, &spo2Ok, &hrVal, &hrOk);
  if (hrOk) {
    int32_t h = (int32_t)(hrVal * HR_CORRECTION + 0.5f);
    hrVal = (h >= HR_MIN && h <= HR_MAX) ? h : 0;
    hrOk  = (hrVal > 0) ? 1 : 0;
  }
  if (spo2Ok) spo2Val = constrain(spo2Val - SPO2_OFFSET, 0, 100);
}

void accumulate() {
  if (hrOk && spo2Ok && nSamples < MAX_SAMPLES) {
    hrArr[nSamples] = hrVal; spo2Arr[nSamples] = spo2Val; nSamples++;
  }
}

