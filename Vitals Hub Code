void drawDisplay() {
  bool tempFresh    = gotModuleTemp && (millis() - lastTempTime < TEMP_STALE_MS);
  bool respFresh    = (gotModuleResp && millis() - lastRespTime < RESP_STALE_MS) ||
                      (gotResp && millis() - lastBleRespTime < RESP_STALE_MS);
  bool respConn     = (rClient && rClient->isConnected());
  int  dispResp     = gotModuleResp ? moduleResp : bleResp;

  display.clearDisplay(); display.setTextSize(1);
  display.setCursor(14, 0); display.println(F("VitaTrack Hub"));
  display.drawLine(0, 9, SCREEN_WIDTH-1, 9, SSD1306_WHITE);

  display.setCursor(0, 12);
  display.print(F("HR:"));
  if (hrOk && hrVal > 0) display.print(hrVal); else display.print(F("--"));
  display.print(F("b  O2:"));
  if (spo2Ok && spo2Val > 0) display.print(spo2Val); else display.print(F("--"));
  display.print(F("%"));

  display.setCursor(0, 22);
  display.print(F("Tmp:"));
  if (tempFresh) { display.print(moduleTemp, 1); display.print(F("C")); }
  else display.print(F("--"));

  display.setCursor(0, 32);
  display.print(F("Resp:"));
  if (respFresh && dispResp >= 0) { display.print(dispResp); display.print(F("br/m")); }
  else display.print(F("--"));

  display.setCursor(0, 42);
  if (!fingerOn()) display.print(F("> Place finger <"));
  else display.print(F("Measuring...    "));

  display.drawLine(0, 52, SCREEN_WIDTH-1, 52, SSD1306_WHITE);

  unsigned long secs = (SEND_INTERVAL - (millis() - lastSend)) / 1000;
  display.setCursor(0, 55);
  if (staConnected) display.print(F("W*"));
  else { display.print(F("W-Q:")); display.print(queuedReadings); }
  display.print(F(" T")); display.print(tempFresh ? F("*") : F("-"));
  display.print(F(" R")); display.print(respFresh ? F("*") : F("-"));
  display.print(F(" n=")); display.print(nSamples);
  display.print(F(" ")); display.print(secs); display.print(F("s"));
  display.display();
}

// ─────────────────────────────────────────────────────────────
// SETUP
// ─────────────────────────────────────────────────────────────
void setup() {
  Serial.begin(BAUD);
  pinMode(CONFIG_BTN_PIN, INPUT_PULLUP);
  pinMode(LED_PIN, OUTPUT);

  if (!display.begin(SSD1306_SWITCHCAPVCC, OLED_ADDRESS)) {
    while (true) { digitalWrite(LED_PIN, !digitalRead(LED_PIN)); delay(300); }
  }
  display.setTextColor(SSD1306_WHITE);
  oledMsg("VitaTrack Hub", "Starting...");

  loadConfig();
  initSPIFFS();

  // Check BOOT button → open internet config portal
  bool forcePortal = false;
  unsigned long t0 = millis();
  oledMsg("Hold button", "for WiFi setup");
  while (millis() - t0 < BTN_HOLD_MS) {
    if (digitalRead(CONFIG_BTN_PIN) == HIGH) break;
    delay(50);
  }
  if (digitalRead(CONFIG_BTN_PIN) == LOW) forcePortal = true;
  if (forcePortal) { launchCaptivePortal(); return; }

  // Start hub AP (always — modules connect here)
  startHubAP();

  // Setup AP web server for modules and hub config
  setupAPServer();

  // Connect to internet WiFi in background (STA mode alongside AP)
  if (strlen(cfgWifiSsid) > 0) {
    oledMsg("Internet WiFi", "Connecting...");
    WiFi.begin(cfgWifiSsid, cfgWifiPass);
    unsigned long wt = millis();
    while (WiFi.status() != WL_CONNECTED && millis() - wt < 10000) {
      delay(200); Serial.print(".");
    }
    Serial.println();
    if (WiFi.status() == WL_CONNECTED) {
      staConnected = true;
      Serial.print(F("[WiFi] Internet: ")); Serial.println(WiFi.localIP());
    } else {
      Serial.println(F("[WiFi] Internet not available — running offline"));
    }
  } else {
    Serial.println(F("[WiFi] No internet credentials — hold BOOT to configure"));
  }

  // MAX30102
  oledMsg("Sensor", "Initialising...");
  if (!sensor.begin(Wire, I2C_SPEED_FAST)) {
    oledMsg("MAX30102", "Not found!"); halt("[ERR] MAX30102");
  }
  sensor.setup(60, 4, 2, 100, 411, 4096);

  // BLE
  NimBLEDevice::init("VITALS_HUB");
  NimBLEDevice::setPower(ESP_PWR_LVL_P9);
  Serial.println(F("[BLE] Ready"));

  display.clearDisplay(); display.setTextSize(1);
  display.setCursor(0, 0);  display.println(F("VitaTrack Hub Ready"));
  display.setCursor(0, 12); display.print(F("Hub AP: ")); display.println(HUB_AP_SSID);
  display.setCursor(0, 22); display.print(F("Pass: ")); display.println(cfgDeviceId);
  display.setCursor(0, 32); display.print(F("Internet: "));
  display.println(staConnected ? F("OK") : F("Offline"));
  display.setCursor(0, 42); display.print(F("Device: ")); display.println(cfgDeviceId);
  if (queuedReadings > 0) {
    display.setCursor(0, 52);
    display.print(F("Queued: ")); display.print(queuedReadings);
  }
  display.display(); delay(4000);

  lastSend      = millis();
  lastWifiRetry = millis();
  lastRetry     = millis();
}

// ─────────────────────────────────────────────────────────────
// LOOP
// ─────────────────────────────────────────────────────────────
void loop() {
  // AP server (module data + hub config page)
  apServer.handleClient();

  // Config button (hold 3s → internet WiFi setup)
  if (digitalRead(CONFIG_BTN_PIN) == LOW) {
    unsigned long t = millis();
    while (digitalRead(CONFIG_BTN_PIN) == LOW && millis() - t < BTN_HOLD_MS) delay(50);
    if (millis() - t >= BTN_HOLD_MS) { launchCaptivePortal(); return; }
  }

  wifiMaintain();
  bleMaintain();
  collectSamples();
  if (fingerOn()) { measure();
  
  // === APPLY CALIBRATION ===
  if (hrOk) {
    hrVal = (int32_t)(hrVal * calibHrSlope + calibHrOffset + 0.5f);
    hrVal = constrain(hrVal, HR_MIN, HR_MAX);
  }
  if (spo2Ok) {
    spo2Val = (int32_t)(spo2Val * calibSpo2Slope + calibSpo2Offset + 0.5f);
    spo2Val = constrain(spo2Val, 70, 100);  // typical SpO2 range
  }
  accumulate(); }
  drawDisplay();

  if (millis() - lastSend >= SEND_INTERVAL) {
    lastSend = millis();
    handleSend();
  }
}
