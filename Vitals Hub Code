void oledMsg(const char* a, const char* b) {
  display.clearDisplay(); display.setTextSize(1);
  display.setCursor(0, 20); display.println(a);
  display.setCursor(0, 35); display.println(b);
  display.display();
}

void halt(const char* msg) {
  Serial.println(msg); while (true) delay(1000);
}

// ─────────────────────────────────────────────────────────────
// CONFIG
// ─────────────────────────────────────────────────────────────
void loadConfig() {
  prefs.begin("vitatrack", true);
  String did = prefs.getString("device_id", DEFAULT_DEVICE_ID);
  String url = prefs.getString("flask_url", DEFAULT_FLASK_URL);
  String ssid = prefs.getString("wifi_ssid", "");
  String pass = prefs.getString("wifi_pass", "");

  // Calibration
  calibHrSlope   = prefs.getFloat("calib_hr_slope",   DEFAULT_CALIB_SLOPE);
  calibHrOffset  = prefs.getFloat("calib_hr_offset",  DEFAULT_CALIB_OFFSET);
  calibSpo2Slope = prefs.getFloat("calib_spo2_slope", DEFAULT_CALIB_SLOPE);
  calibSpo2Offset= prefs.getFloat("calib_spo2_offset",DEFAULT_CALIB_OFFSET);
  prefs.end();
  strncpy(cfgDeviceId, did.c_str(),  sizeof(cfgDeviceId)-1);
  strncpy(cfgFlaskUrl, url.c_str(),  sizeof(cfgFlaskUrl)-1);
  strncpy(cfgWifiSsid, ssid.c_str(), sizeof(cfgWifiSsid)-1);
  strncpy(cfgWifiPass, pass.c_str(), sizeof(cfgWifiPass)-1);
  Serial.print(F("[CFG] Device: "));  Serial.println(cfgDeviceId);
  Serial.printf("[CFG] Calibration HR: %.3f x + %.2f | SpO2: %.3f x + %.2f\n",
                calibHrSlope, calibHrOffset, calibSpo2Slope, calibSpo2Offset);
}

void saveConfig(const char* did, const char* url, const char* ssid, const char* pass,
                float hrSlope, float hrOff, float spo2Slope, float spo2Off) {
  prefs.begin("vitatrack", false);
  prefs.putString("device_id", did);
  prefs.putString("flask_url", url);
  prefs.putString("wifi_ssid", ssid);
  prefs.putString("wifi_pass", pass);
  
  prefs.putFloat("calib_hr_slope", hrSlope);
  prefs.putFloat("calib_hr_offset", hrOff);
  prefs.putFloat("calib_spo2_slope", spo2Slope);
  prefs.putFloat("calib_spo2_offset", spo2Off);
  
  prefs.end();
  Serial.println(F("[CFG] Saved with calibration"));
}

// ─────────────────────────────────────────────────────────────
// START HUB AP (always on — modules connect here)
// Password = Device ID so only paired modules can connect
// ─────────────────────────────────────────────────────────────
void startHubAP() {
  // Use AP+STA mode so both AP and internet work simultaneously
  WiFi.mode(WIFI_AP_STA);

  IPAddress apIP(192, 168, 4, 1);
  WiFi.softAPConfig(apIP, apIP, IPAddress(255, 255, 255, 0));
  WiFi.softAP(HUB_AP_SSID, cfgDeviceId);   // password = device ID

  Serial.print(F("[AP] SSID: "));     Serial.println(HUB_AP_SSID);
  Serial.print(F("[AP] Password: ")); Serial.println(cfgDeviceId);
  Serial.print(F("[AP] IP: "));       Serial.println(WiFi.softAPIP());

  // Display AP info on OLED briefly
  display.clearDisplay(); display.setTextSize(1);
  display.setCursor(0, 0);  display.println(F("Hub AP Active"));
  display.setCursor(0, 12); display.print(F("SSID: ")); display.println(HUB_AP_SSID);
  display.setCursor(0, 24); display.print(F("Pass: ")); display.println(cfgDeviceId);
  display.setCursor(0, 36); display.print(F("IP: "));   display.println(WiFi.softAPIP());
  display.display(); delay(3000);
}

