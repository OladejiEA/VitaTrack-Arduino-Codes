      "<title>VitaTrack Temp Config</title>"
      "<style>"
      "body{font-family:sans-serif;max-width:420px;margin:0 auto;"
      "padding:24px 20px;background:#f8fafc}"
      "h2{color:#0f172a;font-size:20px;margin-bottom:4px}"
      ".sub{color:#64748b;font-size:13px;margin-bottom:18px}"
      "label{font-size:13px;font-weight:600;color:#374151;"
      "display:block;margin-bottom:5px}"
      "input{width:100%;padding:10px 14px;margin-bottom:14px;"
      "border:1.5px solid #d1d5db;border-radius:10px;"
      "font-size:14px;box-sizing:border-box}"
      "button{width:100%;padding:13px;background:#2563eb;color:#fff;"
      "border:none;border-radius:10px;font-size:15px;"
      "font-weight:600;cursor:pointer}"
      ".card{background:#fff;border-radius:14px;padding:20px;"
      "box-shadow:0 2px 10px rgba(0,0,0,.08)}"
      ".info{background:#f0fdf4;border:1px solid #86efac;"
      "border-radius:8px;padding:10px 14px;"
      "font-size:12px;color:#166534;margin-bottom:14px;line-height:1.6}"
      ".warn{background:#fffbeb;border:1px solid #fcd34d;"
      "border-radius:8px;padding:10px 14px;"
      "font-size:12px;color:#92400e;margin-bottom:14px;line-height:1.6}"
      "</style></head><body>"
      "<div style='text-align:center;margin-bottom:14px'>"
      "<div style='font-size:36px'>🌡️</div>"
      "<h2>Temp Module Config</h2>"
      "<div class='sub'>Device: " + String(cfgDeviceId) + "</div>"
      "</div>"
      "<div class='card'>"
      "<div class='info'>"
      "&#x1F4F6; Connected to Hub AP: <strong>" + String(HUB_AP_SSID) + "</strong><br>"
      "&#x1F4CD; Module IP: <strong>" + WiFi.localIP().toString() + "</strong>"
      "</div>"
      "<div class='warn'>"
      "&#x26A0; To re-pair with a different hub, change the "
      "<strong>Hub AP Password</strong> to the new hub's Device ID."
      "</div>"
      "<label>Device ID</label>"
      "<input id='did' value='" + String(cfgDeviceId) + "'>"
      "<label>Hub AP Password (= Hub Device ID)</label>"
      "<input id='hpass' value='" + String(cfgHubPass) + "'>"
      "<button onclick='save()'>💾 Save &amp; Restart</button>"
      "</div>"
      "<script>"
      "function save(){"
      "var d=document.getElementById('did').value.trim(),"
      "h=document.getElementById('hpass').value.trim();"
      "if(!d||!h){alert('All fields required');return;}"
      "fetch('/save',{method:'POST',"
      "headers:{'Content-Type':'application/json'},"
      "body:JSON.stringify({device_id:d,hub_pass:h})})"
      ".then(()=>{"
      "document.body.innerHTML='<div style=\"text-align:center;padding:60px\">"
