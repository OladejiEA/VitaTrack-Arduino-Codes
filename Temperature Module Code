// ═══════════════════════════════════════════════════════════════
// VitaTrack — Temperature Module (ESP32-C3 Super Mini)
// DS18B20 | Connects to Hub AP | POSTs temp to hub every 60s
//
// Pins:
//   DS18B20 DATA → GPIO 4  (4.7kΩ pull-up to 3.3V)
//   LED R        → GPIO 10
//   LED G        → GPIO 2
//   LED B        → GPIO 1
//   BOOT button  → GPIO 9 (onboard)
//
// ── How pairing works ─────────────────────────────────────────
// Default hub AP SSID    : "VitaTrack-Hub"
// Default hub AP password: "ESP32-001" (hub's device ID)
// Module connects using that password by default
//
// ── Re-pairing ────────────────────────────────────────────────
// 1. Connect laptop/phone to hub's AP ("VitaTrack-Hub")
// 2. Use IP scanner (e.g. Advanced IP Scanner) to find module IP
// 3. Open http://<module-ip> in browser
// 4. Change "Hub AP Password" to new hub's Device ID
// 5. Save — module reconnects with new password
//
// ── BOOT button (GPIO9) ───────────────────────────────────────
// Hold 3s  → manual config portal (temporary AP for WiFi setup)
// Hold 8s  → factory reset
//
// LED meanings:
//   RED solid        = not connected to hub AP
//   YELLOW blinking  = connecting to hub AP
//   BLUE solid       = connected, idle between sends
//   YELLOW solid     = reading sensor + sending
//   GREEN solid 5s   = sent successfully
//   YELLOW solid 5s  = send failed — retrying
//   PURPLE solid     = DS18B20 not found
//   CYAN blinking    = config portal active
//   WHITE flashes    = entering config / factory reset
// ═══════════════════════════════════════════════════════════════

#include <OneWire.h>
#include <DallasTemperature.h>
#include <Preferences.h>
#include <WiFi.h>
#include <HTTPClient.h>
#include <WebServer.h>
#include <ArduinoJson.h>

// ── Pins ──────────────────────────────────────────────────────
#define DATA_PIN      4
#define LED_R         10
#define LED_G         2
#define LED_B         1
#define BOOT_BTN      9

// ── Hub connection ────────────────────────────────────────────
#define HUB_AP_SSID        "VitaTrack-Hub"
#define DEFAULT_HUB_PASS   "ESP32-001"     // default = hub device ID
#define HUB_IP             "192.168.4.1"
#define HUB_TEMP_ENDPOINT  "http://192.168.4.1/temp"

// ── Config portal ─────────────────────────────────────────────
#define SHORT_HOLD_MS   3000UL
#define LONG_HOLD_MS    8000UL

// ── Timing ────────────────────────────────────────────────────
#define SEND_INTERVAL   60000UL
#define PEAK_WINDOW     60000UL
#define WIFI_RETRY_MS   20000UL

// ── Config ────────────────────────────────────────────────────
char cfgDeviceId[32];
char cfgHubPass[32];   // = hub's device ID

// ── Objects ───────────────────────────────────────────────────
OneWire           oneWire(DATA_PIN);
DallasTemperature sensors(&oneWire);
Preferences       prefs;
WebServer         cfgServer(80);   // config page at module's own IP

// ── State ─────────────────────────────────────────────────────
float currentTemp    = -99;
float peakTemp       = -99;
unsigned long peakStartTime  = 0;
unsigned long lastSend       = 0;
unsigned long lastWifiRetry  = 0;
unsigned long lastBlink      = 0;
bool blinkOn       = false;
bool wifiConnected = false;
bool cfgServerRunning = false;

unsigned long buttonPressTime = 0;
bool buttonWasPressed = false;

// ── LED ───────────────────────────────────────────────────────
void setLED(bool r, bool g, bool b) {
  digitalWrite(LED_R, r ? HIGH : LOW);
  digitalWrite(LED_G, g ? HIGH : LOW);
  digitalWrite(LED_B, b ? HIGH : LOW);
}
void ledRed()    { setLED(1, 0, 0); }
void ledGreen()  { setLED(0, 1, 0); }
void ledBlue()   { setLED(0, 0, 1); }
void ledYellow() { setLED(1, 1, 0); }
void ledCyan()   { setLED(0, 1, 1); }
void ledWhite()  { setLED(1, 1, 1); }
void ledPurple() { setLED(1, 0, 1); }
void ledOff()    { setLED(0, 0, 0); }

// ── Config helpers ────────────────────────────────────────────
void loadConfig() {
  prefs.begin("vitatemp", true);
  String did  = prefs.getString("device_id",  "TEMP-001");
  String hpas = prefs.getString("hub_pass",   DEFAULT_HUB_PASS);
  prefs.end();
  strncpy(cfgDeviceId, did.c_str(),  sizeof(cfgDeviceId)-1);
  strncpy(cfgHubPass,  hpas.c_str(), sizeof(cfgHubPass)-1);
  Serial.print(F("[CFG] Device: "));   Serial.println(cfgDeviceId);
  Serial.print(F("[CFG] Hub pass: ")); Serial.println(cfgHubPass);
}

void saveConfig(const char* did, const char* hpass) {
  prefs.begin("vitatemp", false);
  prefs.putString("device_id", did);
  prefs.putString("hub_pass",  hpass);
  prefs.end();
  Serial.println(F("[CFG] Saved"));
}

void resetAllConfig() {
  prefs.begin("vitatemp", false);
  prefs.clear();
  prefs.end();
  for (int i = 0; i < 5; i++) { ledRed(); delay(200); ledOff(); delay(200); }
  ESP.restart();
}

// ─────────────────────────────────────────────────────────────
